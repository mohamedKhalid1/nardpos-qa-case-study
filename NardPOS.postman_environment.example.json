{
  "id": "nardpos-env-example",
  "name": "NardPOS Environment Example",
  "_postman_variable_scope": "environment",
  "values": [
    {
      "key": "base_url",
      "value": "https://api.example.com",
      "type": "default",
      "enabled": true
    },
    {
      "key": "username",
      "value": "your_username",
      "type": "default",
      "enabled": true
    },
    {
      "key": "password",
      "value": "your_password",
      "type": "default",
      "enabled": true
    },
    {
      "key": "token",
      "value": "your_access_token",
      "type": "default",
      "enabled": true
    },
    {
      "key": "sale_id",
      "value": "example_sale_id",
      "type": "default",
      "enabled": true
    }
  ]
}